# Crie um cliente OAuth 2.0 do tipo "Aplicativo da Web" no Google Cloud.
# Para testes locais, autorize a origem: http://localhost:5173
VITE_GOOGLE_CLIENT_ID=

# Use o mesmo Client ID no servidor para validar o campo "aud" do token.
GOOGLE_CLIENT_ID=

# Gere um segredo aleatório com pelo menos 32 caracteres. Nunca envie ao Git.
SESSION_SECRET=

# Quando publicar, inclua o domínio HTTPS separado por vírgula.
# Exemplo: https://consulta.seudominio.com.br
AUTH_ALLOWED_ORIGINS=

# Contas Google autorizadas a conceder e revogar cortesias Premium.
# Separe mais de um e-mail por vírgula. Não use uma senha administrativa paralela.
ADMIN_GOOGLE_EMAILS=

# Porta local do servidor de autenticação e pagamentos.
AUTH_PORT=8788

# Checkout Mercado Pago em modo de teste. Mantenha o Access Token somente no servidor.
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=
MERCADO_PAGO_USE_SANDBOX=true

# Use as credenciais da aplicação Mercado Pago criada para o produto Assinaturas.
MERCADO_PAGO_SUBSCRIPTIONS_ACCESS_TOKEN=
MERCADO_PAGO_SUBSCRIPTIONS_WEBHOOK_SECRET=
# E-mail da conta de teste do tipo Comprador criada nessa mesma aplicação.
MERCADO_PAGO_TEST_PAYER_EMAIL=
# Public Key da mesma aplicação/conta vendedora usada no Access Token acima.
# Ela é pública e permite ao Brick tokenizar o cartão sem passar seus dados pelo servidor.
VITE_MERCADO_PAGO_PUBLIC_KEY=
VITE_MERCADO_PAGO_USE_SANDBOX=true

# Endereço do frontend e URL HTTPS temporária usada pelo Mercado Pago para o Webhook.
APP_BASE_URL=http://localhost:5173
MERCADO_PAGO_WEBHOOK_URL=

# O arquivo JSON é somente para o backtest local.
BILLING_STORAGE_MODE=local
LOCAL_BILLING_DB=data/dev-billing.json
LOCAL_PROPERTY_SEARCH_DB=data/dev-property-searches.json

# Na Vercel use BILLING_STORAGE_MODE=postgres e a conexão agrupada (pooled) do Neon.
# Nunca exponha DATABASE_URL com o prefixo VITE_.
DATABASE_URL=
DATABASE_POOL_MAX=2
